# A simple C minor groove: four-on-the-floor drums plus a walking
# bass line that climbs the C minor 7 chord (C - Eb - G - Bb).
#
# Each note holds for a full beat (4 sixteenth notes) thanks to the
# `.` sustain cells.

bpm: 100
steps: 16

kick:    x---x---x---x---
snare:   ----x-------x---
hihat:   x-x-x-x-x-x-x-x-

bass:    C2 . . . Eb2 . . . G2 . . . Bb2 . . .
